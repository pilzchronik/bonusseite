<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Interaktives Linkverzeichnis der Pilz-Chronik</title>
  <meta name="description" content="Durchsuchbares Linkverzeichnis der Pilz-Chronik – Onlinequellen, Archive, Karten und Zeitungsartikel aus Band 1 und 2." />
  <link rel="canonical" href="https://pilzchronik.github.io/bonusseite/links.html" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root { color-scheme: light; }
    body { font-family: "IBM Plex Sans", system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background:#faf9f6; color:#364152; }
    .font-code { font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace; }
    .category-button.active { background:#475569; color:#fff; }
    .link-card { transition: box-shadow .25s ease, transform .25s ease; }
    .link-card:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(0,0,0,.1), 0 4px 6px -2px rgba(0,0,0,.05); }
    html { scroll-behavior: smooth; }
    .sticky-nav { position: sticky; top: 0; z-index: 10; }
  </style>
</head>

<body class="text-slate-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="text-center mb-10">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-800 tracking-tight">
        Linkverzeichnis der Pilz-Chronik
      </h1>
      <p class="mt-4 text-lg text-slate-600 max-w-3xl mx-auto">
        Interaktive Liste aller Online-Quellen aus Band 1 und 2 der Chronik.  
        Filtern nach Kategorie oder per Suche (Titel, Kurzlink, URL).
      </p>

      <a href="links.pdf" class="inline-block mt-6 bg-slate-800 text-white px-5 py-2 rounded-md hover:bg-slate-700 transition" download>
        📄 Download als interaktives PDF
      </a>
    </header>

    <nav class="sticky-nav bg-slate-100 p-4 rounded-xl shadow-sm mb-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div class="w-full md:w-1/2 lg:w-1/3">
          <input id="searchInput" type="text" placeholder="Suche in Titel, Kurzlink oder URL …"
            class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-500 focus:border-slate-500 transition" />
        </div>
        <div id="category-filter" class="flex flex-wrap items-center justify-center gap-2">
          <button data-filter="all"
            class="category-button active px-4 py-2 bg-white hover:bg-slate-200 text-slate-700 rounded-lg text-sm font-medium transition shadow-sm">
            Alle
          </button>
        </div>
      </div>
    </nav>

    <main id="link-container" class="space-y-12"></main>
  </div>

  <script>
  // --- Daten (gekürzt für Übersicht; Vollversion folgt in "linkData.js") ---
  const linkData = []; // Platzhalter, siehe unten Hinweis

  // --- Rendering & Logik ---
  document.addEventListener("DOMContentLoaded", () => {
    const linkContainer = document.getElementById("link-container");
    const categoryFilterContainer = document.getElementById("category-filter");
    const searchInput = document.getElementById("searchInput");

    const createLinkCard = (item) => {
      const noteHtml = item.note ? `<p class="mt-2 text-sm text-amber-700 bg-amber-100 p-2 rounded-md">ⓘ ${item.note}</p>` : "";
      const dataSearch = `${item.title} ${item.shortlink || ""} ${item.url}`.toLowerCase();
      return `
        <div class="link-card bg-white p-5 rounded-lg shadow-md border border-slate-200/80"
             data-search="${dataSearch.replace(/"/g, "&quot;")}">
          <h3 class="text-lg font-semibold text-slate-800">${item.title}</h3>
          ${noteHtml}
          <div class="mt-4 space-y-3 text-sm">
            <div class="flex items-start">
              <span class="font-medium text-slate-500 w-32 shrink-0">Kurzlink:</span>
              <span class="font-code text-slate-700 break-all">${item.shortlink || "—"}</span>
            </div>
            <div class="flex items-start">
              <span class="font-medium text-slate-500 w-32 shrink-0">Vollständige URL:</span>
              <a href="${item.url}" target="_blank" rel="noopener noreferrer"
                 class="font-code text-sky-700 hover:text-sky-900 hover:underline break-all">${item.url}</a>
            </div>
            <div class="flex items-start">
              <span class="font-medium text-slate-500 w-32 shrink-0">Seitenzahl:</span>
              <span class="text-slate-700">📖 ${item.pages}</span>
            </div>
          </div>
          <div class="mt-4 flex items-center justify-end gap-2">
            <button class="copy-btn text-xs bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold py-1 px-3 rounded-full transition"
                    data-url="${item.url}">
              URL kopieren 📋
            </button>
          </div>
        </div>`;
    };

    const handleSearchAndFilter = () => {
      const term = searchInput.value.trim().toLowerCase();
      const active = document.querySelector(".category-button.active").dataset.filter;
      linkData.forEach(cat => {
        const section = document.getElementById(cat.id);
        let anyVisible = false;
        if (active !== "all" && active !== cat.id) { section.style.display = "none"; return; }
        section.style.display = "block";
        section.querySelectorAll(".link-card").forEach(card => {
          const hay = card.dataset.search;
          const show = !term || hay.includes(term);
          card.style.display = show ? "block" : "none";
          if (show) anyVisible = true;
        });
        section.style.display = anyVisible ? "block" : "none";
      });
    };

    // (weiterer JS-Code bleibt wie zuvor)
  });
  </script>
</body>
</html>
